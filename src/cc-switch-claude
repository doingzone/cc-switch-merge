#!/usr/bin/env bash
# cc-switch-claude wrapper — 只处理 claude 配置 (settings.json)
# 不动 codex CLI / codex APP 的任何配置文件 (config.toml, auth.json)
# 其他功能跟 cc-switch.full 一样: 备份 + VcXsrv 启动 + 接管恢复 + 热切换合并 + 看门狗
set -euo pipefail

echo "============================================" > /tmp/cc-switch-claude-wrapper.log
echo "[cc-switch-claude WRAPPER v1] 仅 claude 模式 (跳过 codex) (日志: /tmp/cc-switch-claude-wrapper.log)"
echo "============================================" | tee -a /tmp/cc-switch-claude-wrapper.log

SETTINGS_FILE="$HOME/.claude/settings.json"
BACKUP_DIR="$HOME/.claude/backups"
MERGE_SCRIPT="$HOME/.codex/cc-switch-merge.py"
REAL_CC_SWITCH="/usr/bin/cc-switch"
VCXSRV="/mnt/c/Program Files/VcXsrv/vcxsrv.exe"
VCX_DISPLAY=":1"
ORIGINAL_DISPLAY="${DISPLAY:-}"
TARGET_DISPLAY="$VCX_DISPLAY"

# 保存原始参数,供看门狗重启时使用
CC_SWITCH_ARGS=("$@")

# --- WSL 稳定性修复 ---
export LIBGL_ALWAYS_SOFTWARE=1
export WEBKIT_DISABLE_COMPOSITING_MODE=1
export GDK_BACKEND=x11

# D-Bus session bus (WebKit2GTK 依赖)
if [[ -z "${DBUS_SESSION_BUS_ADDRESS:-}" ]]; then
    eval "$(dbus-launch --sh-syntax)" 2>/dev/null || true
fi

# Ensure backup directory exists
mkdir -p "$BACKUP_DIR" || true

CONFIG_BACKUP=""

# Back up settings.json (唯一需要备份的文件)
if [[ -f "$SETTINGS_FILE" ]]; then
    ts=$(date +%Y%m%d-%H%M%S)
    CONFIG_BACKUP="$BACKUP_DIR/settings-${ts}.json"
    cp "$SETTINGS_FILE" "$CONFIG_BACKUP" || true
    echo "[cc-switch-claude-backup] ✓ settings.json 已备份" | tee -a /tmp/cc-switch-claude-wrapper.log
fi

# Check if VcXsrv is already functional on :1
if ! xdpyinfo -display "$VCX_DISPLAY" >/dev/null 2>&1; then
    echo "[cc-switch-claude] 启动 VcXsrv on $VCX_DISPLAY ..."
    "$VCXSRV" "$VCX_DISPLAY" -ac -multiwindow -clipboard -nowgl 2>/dev/null &
    for i in $(seq 1 10); do
        if xdpyinfo -display "$VCX_DISPLAY" >/dev/null 2>&1; then
            break
        fi
        sleep 1
    done
fi

if ! xdpyinfo -display "$VCX_DISPLAY" >/dev/null 2>&1; then
    if [[ -n "$ORIGINAL_DISPLAY" ]] && xdpyinfo -display "$ORIGINAL_DISPLAY" >/dev/null 2>&1; then
        TARGET_DISPLAY="$ORIGINAL_DISPLAY"
        echo "[cc-switch-claude] VcXsrv on $VCX_DISPLAY 未就绪,回退到现有 DISPLAY=$TARGET_DISPLAY"
    else
        echo "[cc-switch-claude] 警告: $VCX_DISPLAY 不可用,继续尝试启动 cc-switch"
    fi
fi

# Run cc-switch via VcXsrv
export DISPLAY="$TARGET_DISPLAY"

# --- X11 看门狗 ---
WATCHDOG_MAX_RESTARTS=3
WATCHDOG_INTERVAL=5

x11_watchdog() {
    local cc_pid=$1
    local display=$2
    local restart_count=0

    while true; do
        sleep "$WATCHDOG_INTERVAL"

        if ! kill -0 "$cc_pid" 2>/dev/null; then
            return 0
        fi

        if ! xdpyinfo -display "$display" >/dev/null 2>&1; then
            restart_count=$((restart_count + 1))
            echo "[cc-switch-claude-watchdog] X11 显示 $display 连接丢失 (第${restart_count}次/${WATCHDOG_MAX_RESTARTS}次上限)"

            if [ "$restart_count" -gt "$WATCHDOG_MAX_RESTARTS" ]; then
                echo "[cc-switch-claude-watchdog] 已达最大重启次数,放弃监控"
                kill "$cc_pid" 2>/dev/null || true
                return 1
            fi

            kill "$cc_pid" 2>/dev/null || true
            wait "$cc_pid" 2>/dev/null || true
            sleep 1

            "$VCXSRV" "$display" -ac -multiwindow -clipboard -nowgl 2>/dev/null &
            sleep 2

            if ! xdpyinfo -display "$display" >/dev/null 2>&1; then
                echo "[cc-switch-claude-watchdog] VcXsrv 重启失败,放弃"
                return 1
            fi

            echo "[cc-switch-claude-watchdog] 重新启动 cc-switch ..."
            "$REAL_CC_SWITCH" "${CC_SWITCH_ARGS[@]}" &
            cc_pid=$!
        fi
    done
}

# 启动 cc-switch 并 fork 看门狗
"$REAL_CC_SWITCH" "${CC_SWITCH_ARGS[@]}" &
CC_PID=$!

x11_watchdog "$CC_PID" "$TARGET_DISPLAY" &
WATCHDOG_PID=$!

# 启动日志 watcher: 只监听 claude 事件 (codex 事件忽略)
# 热切换 claude / Claude Live 接管 都触发合并
DEBUG_LOG="/tmp/cc-switch-claude-watcher-debug.log"
CC_LOG="$HOME/.cc-switch/logs/cc-switch.log"
if [[ -f "$CC_LOG" ]]; then
    (
        set +e  # watcher 不能因为单次 merge 失败就死, 必须持续循环
        LAST_SIZE=0
        ITER=0
        echo "[watcher-claude] start, CC_PID=$CC_PID, CC_LOG=$CC_LOG" >> "$DEBUG_LOG"
        while kill -0 "$CC_PID" 2>/dev/null; do
            ITER=$((ITER + 1))
            sleep 2
            [[ -f "$CC_LOG" ]] || { echo "[watcher-claude] iter=$ITER CC_LOG gone, continue" >> "$DEBUG_LOG"; continue; }
            CUR_SIZE=$(stat -c%s "$CC_LOG" 2>/dev/null || echo 0)
            echo "[watcher-claude] iter=$ITER LAST=$LAST_SIZE CUR=$CUR_SIZE" >> "$DEBUG_LOG"
            if [[ "$CUR_SIZE" -lt "$LAST_SIZE" ]]; then
                echo "[watcher-claude] iter=$ITER log truncated/rotated: $LAST_SIZE -> $CUR_SIZE, reset LAST_SIZE=0" >> "$DEBUG_LOG"
                LAST_SIZE=0
            fi
            if [[ "$CUR_SIZE" -gt "$LAST_SIZE" ]]; then
                NEW=$(tail -c +$((LAST_SIZE + 1)) "$CC_LOG" 2>/dev/null)
                # 只关心 claude 事件:
                # - 热切换 claude 的目标供应商: 写 settings.json
                # - Claude Live 配置已接管: 写 settings.json (claude Live 接管)
                # 明确跳过 codex 事件
                if echo "$NEW" | grep -qE '热切换 claude 的目标供应商|Claude Live 配置已接管.*代理地址'; then
                    echo "[watcher-claude] iter=$ITER CLAUDE EVENT detected" >> "$DEBUG_LOG"
                    HOT_LINE=$(echo "$NEW" | grep -E '热切换.*目标供应商' | tail -1)
                    if [[ -n "$HOT_LINE" ]]; then
                        # 热切换事件: 提取 provider UUID + app_type (claude)
                        PROVIDER_ID=$(echo "$HOT_LINE" | grep -oP '目标供应商为 \K[a-f0-9-]+')
                        APP_TYPE="claude"
                        MODEL_OVERRIDE=""
                        if [[ -n "$PROVIDER_ID" ]]; then
                            MODEL_OVERRIDE=$(python3 -c "
import sqlite3, json
try:
    conn = sqlite3.connect('$HOME/.cc-switch/cc-switch.db')
    row = conn.execute('SELECT settings_config FROM providers WHERE id = ? AND app_type = ?', ('$PROVIDER_ID', 'claude')).fetchone()
    conn.close()
    if row:
        sc = json.loads(row[0])
        print(sc.get('env', {}).get('ANTHROPIC_MODEL', ''))
except: pass
" 2>/dev/null)
                        fi
                        if [[ -n "$MODEL_OVERRIDE" ]]; then
                            echo "[cc-switch-claude] 热切换: provider=$PROVIDER_ID model=$MODEL_OVERRIDE" | tee -a /tmp/cc-switch-claude-wrapper.log
                        else
                            echo "[cc-switch-claude] 热切换: provider=$PROVIDER_ID (未找到 model)" | tee -a /tmp/cc-switch-claude-wrapper.log
                        fi
                        EXTRA_ARGS=""
                        if [[ -n "$MODEL_OVERRIDE" ]]; then
                            EXTRA_ARGS="--override-model $MODEL_OVERRIDE"
                        fi
                    else
                        # Claude 接管事件: 从 DB 查 is_current=1 的 claude provider model
                        MODEL_OVERRIDE=$(python3 -c "
import sqlite3, json
try:
    conn = sqlite3.connect('$HOME/.cc-switch/cc-switch.db')
    row = conn.execute('SELECT settings_config FROM providers WHERE is_current = 1 AND app_type = ?', ('claude',)).fetchone()
    conn.close()
    if row:
        sc = json.loads(row[0])
        print(sc.get('env', {}).get('ANTHROPIC_MODEL', ''))
except: pass
" 2>/dev/null)
                        EXTRA_ARGS=""
                        if [[ -n "$MODEL_OVERRIDE" ]]; then
                            EXTRA_ARGS="--override-model $MODEL_OVERRIDE"
                            echo "[cc-switch-claude] 接管恢复: model=$MODEL_OVERRIDE (override)" | tee -a /tmp/cc-switch-claude-wrapper.log
                        else
                            echo "[cc-switch-claude] 接管恢复: 未找到 current claude provider model" | tee -a /tmp/cc-switch-claude-wrapper.log
                        fi
                    fi
                    sleep 3
                    echo "[watcher-claude] iter=$ITER after sleep 3, before merge" >> "$DEBUG_LOG"
                    if [[ -f "$MERGE_SCRIPT" ]]; then
                        echo "[cc-switch-claude] 自动合并 (仅 settings.json): $MERGE_SCRIPT $EXTRA_ARGS" | tee -a /tmp/cc-switch-claude-wrapper.log
                        # 只传 settings 相关参数, 不传任何 codex 参数 (merge 脚本会跳过)
                        python3 "$MERGE_SCRIPT" \
                            --settings "$SETTINGS_FILE" \
                            --settings-backup "$CONFIG_BACKUP" \
                            --backup-dir "$BACKUP_DIR" \
                            $EXTRA_ARGS \
                            merge-settings 2>&1 | tee -a /tmp/cc-switch-claude-wrapper.log
                        echo "[watcher-claude] iter=$ITER merge done, RC=${PIPESTATUS[0]}" >> "$DEBUG_LOG"

                        # Race condition 防护: cc-switch 接管时会写 settings.json 覆盖 wrapper 的合并
                        for RETRY in 1 2 3; do
                            sleep 5
                            KEY_COUNT=$(python3 -c "
import json
try:
    d = json.load(open('$SETTINGS_FILE'))
    print(len(d))
except: print(0)
" 2>/dev/null)
                            echo "[watcher-claude] iter=$ITER retry=$RETRY settings.json keys=$KEY_COUNT" >> "$DEBUG_LOG"
                            if [[ "$KEY_COUNT" -ge 10 ]]; then
                                echo "[watcher-claude] iter=$ITER stable after retry=$RETRY" >> "$DEBUG_LOG"
                                break
                            fi
                            echo "[watcher-claude] iter=$ITER cc-switch 覆盖了, retry=$RETRY" | tee -a /tmp/cc-switch-claude-wrapper.log
                            python3 "$MERGE_SCRIPT" \
                                --settings "$SETTINGS_FILE" \
                                --settings-backup "$CONFIG_BACKUP" \
                                --backup-dir "$BACKUP_DIR" \
                                $EXTRA_ARGS \
                                merge-settings 2>&1 | tee -a /tmp/cc-switch-claude-wrapper.log
                        done
                    fi
                fi
                LAST_SIZE=$CUR_SIZE
            fi
        done
        echo "[watcher-claude] EXIT: kill -0 $CC_PID returned false" >> "$DEBUG_LOG"
    ) &
    WATCHER_PID=$!
    echo "[watcher-claude] started, PID=$WATCHER_PID" >> "$DEBUG_LOG"
fi

# 等待 cc-switch 完成
wait "$CC_PID" 2>/dev/null || true
CC_EXIT=$?

# 关闭看门狗
kill "$WATCHDOG_PID" 2>/dev/null || true
wait "$WATCHDOG_PID" 2>/dev/null || true

# 关闭 watcher
[[ -n "${WATCHER_PID:-}" ]] && kill "$WATCHER_PID" 2>/dev/null || true
[[ -n "${WATCHER_PID:-}" ]] && wait "$WATCHER_PID" 2>/dev/null || true

# 退出前最后合并一次 (仅 settings.json)
echo "[cc-switch-claude] cc-switch 已退出 (CC_EXIT=$CC_EXIT), 最后一次合并..." | tee -a /tmp/cc-switch-claude-wrapper.log
if [[ -f "$MERGE_SCRIPT" ]]; then
    echo "[cc-switch-claude] 调用: python3 $MERGE_SCRIPT ... merge-settings" | tee -a /tmp/cc-switch-claude-wrapper.log
    python3 "$MERGE_SCRIPT" \
        --settings "$SETTINGS_FILE" \
        --settings-backup "$CONFIG_BACKUP" \
        --backup-dir "$BACKUP_DIR" \
        merge-settings 2>&1 | tee -a /tmp/cc-switch-claude-wrapper.log
    RC=${PIPESTATUS[0]}
    echo "[cc-switch-claude] 合并完成, exit=$RC" | tee -a /tmp/cc-switch-claude-wrapper.log
    if [[ $RC -ne 0 ]]; then
        echo "[cc-switch-claude] 合并失败,见上面日志" >&2 | tee -a /tmp/cc-switch-claude-wrapper.log
    fi
else
    echo "[cc-switch-claude] WARN: $MERGE_SCRIPT 不存在,跳过合并" >&2 | tee -a /tmp/cc-switch-claude-wrapper.log
fi

exit $CC_EXIT
